<Window x:Class="MaimLandProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaimLandProject"
        xmlns:res="clr-namespace:MaimLandProject.Res" xmlns:resx="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.Title}" Height="450" Width="800">
    <Grid>
            <Viewbox Stretch="Uniform">
                <Canvas x:Name="MenuCanvas" Width="830" Height="450" >

                    <Canvas.Background>
                        <ImageBrush ImageSource="/Sprites/menuminion.jpg"/>
                    </Canvas.Background>

                <Button Content="{x:Static res:Strings.ButtonStart}" Width="200" Height="65" Canvas.Left="50" 
                Canvas.Bottom="20" Click="Start_Game" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Left" Canvas.Top="360"  />
                        
                    <Button Content="{x:Static res:Strings.ButtonSetting}" Width="200" Height="65" Canvas.Left="315"
                Canvas.Bottom="20" Click="Settings_Game" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Left" Canvas.Top="360"/>
                    <Button Content="{x:Static res:Strings.ButtonExit}" Width="200" Height="65" Canvas.Left="580"
                Canvas.Bottom="20" Click="Exite_Game" Style="{StaticResource MenuButtonStyle}" HorizontalAlignment="Left" Canvas.Top="358" VerticalAlignment="Top" />
                </Canvas>

            </Viewbox>
        </Grid>
</Window>
