<Window x:Class="MaimLandProject.IHM.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaimLandProject.IHM"
        xmlns:res="clr-namespace:MaimLandProject.Res" xmlns:resx="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.TitleWindow1}" Height="450" Width="800">
    <Grid>
        <Viewbox Stretch="Uniform">
            <Canvas x:Name="MenuCanvas" Width="830" Height="450">

                <Canvas.Background>
                    <ImageBrush ImageSource="/Sprites/minionlamp.jpeg"/>
                </Canvas.Background>

                <TextBlock Text="{x:Static res:Strings.ButtonSetting}" FontSize="52" FontWeight="Bold"
                    Foreground="White" Canvas.Left="38" Canvas.Top="80" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.541,0.03" Height="108" Width="278"/>

                <TextBlock Text="{x:Static res:Strings.TextVolume}" FontSize="20" FontWeight="Bold" Canvas.Left="480" Canvas.Top="259" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <TextBlock Name="volumeValueText" FontSize="20" Text="{Binding ElementName=volumeSlider, Path=Value}" Canvas.Left="680" Canvas.Top="293" Height="30" Width="50" RenderTransformOrigin="6.494,1.279" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                <Slider Name="volumeSlider" Minimum="0" Maximum="100" Value="50"
                    TickFrequency="10" IsSnapToTickEnabled="True" Width="254" Canvas.Left="566" Canvas.Top="265" HorizontalAlignment="Center" VerticalAlignment="Top" Height="23" ValueChanged="VolumeSlider_ValueChanged"/>

                <TextBlock Text="{x:Static res:Strings.TextLanguage}" FontSize="20" FontWeight="Bold" Height="30" Width="75" Canvas.Left="480" Canvas.Top="173" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <ComboBox Name="languageComboBox" SelectedIndex="0" Canvas.Left="566" Canvas.Top="177">
                    <ComboBoxItem Content="{x:Static res:Strings.FrenchChoice}" IsSelected="True" />
                    <ComboBoxItem Content="{x:Static res:Strings.EnglishChoice}"/>
                </ComboBox>

                <Button x:Name="Bouton_retour_menu" Content="{x:Static res:Strings.ReToMenu}" Width="100" Height="30" Canvas.Left="643" Canvas.Top="390" Click="Retour_menu" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                <Button x:Name="Bouton_retour_jeu" Content="{x:Static res:Strings.ReToGame}" Width="100" Height="30" Canvas.Left="643" Canvas.Top="338" Click="Retour_jeu" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            </Canvas>
        </Viewbox>
    </Grid>
</Window>
