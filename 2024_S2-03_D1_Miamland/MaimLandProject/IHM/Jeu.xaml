<Window x:Class="MaimLandProject.IHM.Jeu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaimLandProject.IHM"
        mc:Ignorable="d"
        Title="Jeu" Height="650" Width="1200"  >
    <Grid>
        <Canvas x:Name="GameCanvas"  >
            <Canvas.Background>
                <ImageBrush ImageSource="../Sprites/grass.jpg" Stretch="Fill"/>
            </Canvas.Background>
            <Image Source="/Sprites/score1.png" Canvas.Right="95" Canvas.Top="4"/>
            <TextBlock x:Name="ScoreText" Text="Count: 0" FontSize="20" Foreground="White" FontWeight="Bold" Canvas.Right="13" Canvas.Top="10" />
            <Button Content="Settings" Canvas.Left="917" Canvas.Top="5" Height="27" Width="135" HorizontalAlignment="Left" VerticalAlignment="Center" Click="Settings_Game" RenderTransformOrigin="0.537,-0.016" />
        </Canvas>
    </Grid>
</Window>
